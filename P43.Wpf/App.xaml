<Application x:Class="P43.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:P43.Wpf"
             xmlns:vms="clr-namespace:P43.Wpf.ViewModels"
             xmlns:vs="clr-namespace:P43.Wpf.Views.Partials">
    <Application.Resources>
        <ResourceDictionary>
            <DataTemplate DataType="{x:Type vms:StartViewModel}">
                <vs:StartView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vms:LoginViewModel}">
                <vs:LoginView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
